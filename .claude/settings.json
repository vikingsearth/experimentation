{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q 'CLAUDE\\.md$' && sh \"$CLAUDE_PROJECT_DIR/scripts/hook-scripts/post-init-claude-md.sh\" || true"
          }
        ]
      }
    ]
  },
}
